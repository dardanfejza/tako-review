# Backend environment — copy to .env (or load via systemd EnvironmentFile in prod).
# NO LLM KEY exists by design (inference is client-side).

# GitHub OAuth app credentials (blank in the demo until the OAuth app is registered).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# HMAC key for the signed session cookie (Starlette SessionMiddleware). Generate a real
# random value in prod; never commit it.
SESSION_SIGNING_KEY=dev-only-change-me

# SQLAlchemy URL. In prod this points at the SQLite file on the block volume,
# e.g. sqlite:////mnt/data/app.db (TODO: update to the new volume path once redeployed)
DATABASE_URL=sqlite:///./app.db

# Registered GitHub OAuth callback (same-origin backend route).
OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/github/callback

# Rate-limit scaffold is a no-op; one-line switch later.
RATE_LIMIT_ENABLED=false

# dev | prod — controls cookie Secure flag (https_only) and error verbosity.
ENV=dev
LOG_LEVEL=INFO
